# --- Required in production -------------------------------------------------

# JWT session signing key. Generate with: openssl rand -base64 48
# The app refuses to start sessions in production without it.
AUTH_SECRET=

# MongoDB connection string. Local dev: `npm run db` starts a persistent local
# instance at the default below. Production: use MongoDB Atlas
# (mongodb+srv://user:pass@cluster.mongodb.net/michrazim?retryWrites=true&w=majority)
MONGODB_URI=mongodb://127.0.0.1:27017/michrazim

# --- Optional ----------------------------------------------------------------

# Database name (used only when MONGODB_URI has no path component)
MONGODB_DB=michrazim

# Anthropic API key — enables all AI features (risk analyst, Q&A, report memo,
# tender/deals parsing). Missing key = AI features show "unavailable".
ANTHROPIC_API_KEY=

# Model overrides (defaults: opus for smart, sonnet for fast)
ANTHROPIC_MODEL_SMART=
ANTHROPIC_MODEL_FAST=

# Mapbox public token (pk.*) — upgrades the map from free MapLibre/CARTO tiles.
# Never use a secret (sk.*) token here; this value is exposed to the browser.
NEXT_PUBLIC_MAPBOX_TOKEN=
