# Copy this file to `.env` on the VPS (next to docker-compose.yml) and fill in
# real values. `.env` never leaves the server and is never committed to git.

# --- Application secrets --------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
AUTH_SECRET=change-me-to-a-long-random-string

# Bundled Mongo container (default, matches docker-compose.yml's `mongo` service).
# Point this elsewhere (e.g. MongoDB Atlas) instead if you don't want the local container.
MONGODB_URI=mongodb://mongo:27017/michrazim
MONGODB_DB=michrazim

# Empty = free MapLibre/CARTO map. Set a public (pk.) token to upgrade to Mapbox.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Caddy / HTTPS ---------------------------------------------------------
# Domain must have an A/AAAA record pointing at this VPS before first boot.
DOMAIN=example.com
ACME_EMAIL=admin@example.com

# --- Deployed image (set automatically by the GitHub Actions workflow) ---
IMAGE=ghcr.io/fleet-360/michrazim
IMAGE_TAG=latest
